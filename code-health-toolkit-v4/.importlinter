# =============================================================================
# IMPORT-LINTER - Clean Architecture
# =============================================================================
# Ha nincs Clean Architecture struktúrád, töröld ezt a fájlt.
# =============================================================================

[importlinter]
# FONTOS: ez a Python package neve, nem a könyvtár neve.
# Ha a struktúrád src/mypackage/, akkor:
#   root_package = mypackage
#   containers = mypackage
# A mostani root_package = src csak olyan projekteknél jó, ahol az importok is src.* alakúak.
# Más struktúránál cseréld le, különben a quality gate fallback basic checkre vált.
root_package = src
include_external_packages = true

# -----------------------------------------------------------------------------
# LAYER RULES
# infrastructure → adapters → application → domain
# Függőségek csak BEFELÉ!
# -----------------------------------------------------------------------------

[importlinter:contract:layers]
name = Clean Architecture Layers
type = layers
containers = src
layers =
    infrastructure
    adapters
    application
    domain

# -----------------------------------------------------------------------------
# DOMAIN PURITY
# -----------------------------------------------------------------------------
[importlinter:contract:domain_purity]
name = Domain Independence
type = forbidden
source_modules = src.domain
forbidden_modules = fastapi
    flask
    django
    sqlalchemy
    sqlmodel
    requests
    httpx
    aiohttp
    celery
    redis
    boto3

# NOTE: pydantic ENGEDÉLYEZETT Value Object-ként

# -----------------------------------------------------------------------------
# APPLICATION ISOLATION
# -----------------------------------------------------------------------------
[importlinter:contract:application_isolation]
name = Application Layer Isolation
type = forbidden
source_modules = src.application
forbidden_modules = fastapi
    flask
    sqlalchemy
